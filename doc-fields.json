{
  "_comment": "Field dictionary for draft House BL / HAWB documents - the single source of truth shared by server and client. The server (serve-ops.ps1) uses it as the edit WHITELIST (+ maxlen clamp) for every save/submit; bl-form.js renders the on-screen bill from it (order = layout order, w = grid span of 12, multiline = tall box). code is the stable key inside doc_version.fields JSON. seed documents where Save-DocCreate pulls the initial value from (sa = pgsops.shipment_alerts snapshot; erp = bounded read of the station ERP at draft-creation time only); empty seed = manual entry. Unmapped/failed seeds leave the box blank - manual entry is always allowed, an incomplete map never blocks the workflow. STRUCTURED kinds: kind='table' (editable row grid, value = JSON array of {columnCode: text}) and kind='riders' (attachment/rider pages, value = JSON array of page objects) declare 'columns' (per-cell maxlen) and 'maxRows'. 2026-06-12: HBL 'container_info' text box replaced by the structured 'containers' table (old stored versions keep the obsolete key; it is dropped on their next save).",
  "HBL": [
    { "code": "shipper",            "label": "Shipper",                          "w": 6,  "multiline": true,  "maxlen": 600,  "seed": "erp:blhead.shpr_name + shpr_add1..5 | sa.shipper_name" },
    { "code": "hbl_no",             "label": "B/L No.",                          "w": 3,  "multiline": false, "maxlen": 40,   "seed": "sa.house_bill" },
    { "code": "num_originals",      "label": "No. of Original B(s)/L",           "w": 3,  "multiline": false, "maxlen": 40,   "seed": "erp:blhead.no_orig; GUARDRAIL: '0' when blhead.telex_rel is set" },
    { "code": "consignee",          "label": "Consignee",                        "w": 6,  "multiline": true,  "maxlen": 600,  "seed": "erp:blhead.cgne_name + cgne_add1..5 | sa.consignee_name" },
    { "code": "export_refs",        "label": "Export References",                "w": 6,  "multiline": true,  "maxlen": 300,  "seed": "sa.cust_ref" },
    { "code": "notify",             "label": "Notify Party",                     "w": 6,  "multiline": true,  "maxlen": 600,  "seed": "erp:blhead.not1_name + not1_add1..5" },
    { "code": "forwarding_agent",   "label": "Forwarding Agent",                 "w": 6,  "multiline": true,  "maxlen": 300,  "seed": "erp: own office - fm3kco.site(dbname)->owncode -> custsub doc_e_name/doc_e_add1..5" },
    { "code": "precarriage_by",     "label": "Pre-carriage By",                  "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.carr_name" },
    { "code": "place_of_receipt",   "label": "Place of Receipt",                 "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.rece_name" },
    { "code": "delivery_agent",     "label": "Delivery Agent",                   "w": 6,  "multiline": true,  "maxlen": 300,  "seed": "erp:blhead.agnt_name + agnt_add1..5 | custsub by agn2_code" },
    { "code": "vessel_voyage",      "label": "Ocean Vessel / Voyage",            "w": 3,  "multiline": false, "maxlen": 80,   "seed": "sa.vessel_voyage" },
    { "code": "port_of_loading",    "label": "Port of Loading",                  "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.pol_name | sa.pol" },
    { "code": "port_of_discharge",  "label": "Port of Discharge",                "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.pod_name | sa.pod" },
    { "code": "place_of_delivery",  "label": "Place of Delivery",                "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.deli_name" },
    { "code": "final_destination",  "label": "Final Destination",                "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.dest_name" },
    { "code": "freight_payable_at", "label": "Freight Payable At",               "w": 3,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.payable_at" },
    { "code": "freight_terms",      "label": "Freight Terms",                    "w": 3,  "multiline": false, "maxlen": 60,   "seed": "erp:blhead.frt_terms PP->FREIGHT PREPAID else FREIGHT COLLECT, + ' (incoterm)'. PRESENTATION-ONLY: erasing the incoterm here never updates the ERP" },
    { "code": "num_pkgs",           "label": "No. of Pkgs",                      "w": 3,  "multiline": false, "maxlen": 40,   "seed": "erp:blhead.t_book_qty" },
    { "code": "marks_numbers",      "label": "Marks and Numbers",                "w": 3,  "multiline": true,  "maxlen": 1000, "mono": true, "seed": "erp:blitem.mark2 (+mark3); on overflow the FULL text moves to rider page 1, this box goes BLANK (pointer prints in Description only)" },
    { "code": "qty_detail",         "label": "Qty",                              "w": 2,  "multiline": true,  "maxlen": 1000, "mono": true, "seed": "manual: packing-list style quantity per line (e.g. 343 ROLLS), line-aligned with Marks/Description; merged into goodsDescription on the ERP push" },
    { "code": "description",        "label": "Description of Goods",             "w": 3,  "multiline": true,  "maxlen": 2000, "mono": true, "seed": "erp:blitem.good_desc1 | desc2 (+desc3); overflow -> rider page 1 + 'AS PER ATTACHED SHEET'" },
    { "code": "gross_weight",       "label": "Gross Weight",                     "w": 2,  "multiline": true,  "maxlen": 60,   "seed": "erp:blhead.t_book_wgt | sa.total_weight" },
    { "code": "measurement",        "label": "Measurement",                      "w": 2,  "multiline": true,  "maxlen": 60,   "seed": "erp:blhead.t_book_cbm | sa.total_cbm" },
    { "code": "containers",         "label": "Container Particulars",            "w": 12, "kind": "table", "maxRows": 50, "seed": "erp:blcont (container, seal, cont_type, load_qty, pkgs_unit, load_wgt, load_cbm)",
      "columns": [
        { "code": "container_no", "label": "Container No.", "maxlen": 20 },
        { "code": "seal_no",      "label": "Seal No.",      "maxlen": 20 },
        { "code": "cont_type",    "label": "Type",          "maxlen": 10 },
        { "code": "qty",          "label": "Qty",           "maxlen": 10 },
        { "code": "qty_unit",     "label": "Unit",          "maxlen": 12 },
        { "code": "weight_kgs",   "label": "Weight (KGS)",  "maxlen": 14 },
        { "code": "cbm",          "label": "CBM",           "maxlen": 12 }
      ] },
    { "code": "place_of_issue",     "label": "Place of Issue",                   "w": 4,  "multiline": false, "maxlen": 80,   "seed": "erp:blhead.issu_at" },
    { "code": "date_of_issue",      "label": "Date of Issue",                    "w": 4,  "multiline": false, "maxlen": 20,   "seed": "today" },
    { "code": "rider_pages",        "label": "Attachment / Rider Pages",         "w": 12, "kind": "riders", "maxRows": 10, "seed": "erp: auto page 1 when blitem marks/description overflow their boxes",
      "moveFrom": { "marks": "marks_numbers", "qty": "qty_detail", "description": "description" },
      "columns": [
        { "code": "marks",       "label": "Marks and Numbers",    "maxlen": 4000, "multiline": true, "mono": true, "w": 5 },
        { "code": "qty",         "label": "Qty",                  "maxlen": 1000, "multiline": true, "mono": true, "w": 2 },
        { "code": "description", "label": "Description of Goods", "maxlen": 8000, "multiline": true, "mono": true, "w": 8 }
      ] }
  ],
  "HAWB": [
    { "code": "hawb_no",                 "label": "HAWB No.",                              "w": 4,  "multiline": false, "maxlen": 40,   "seed": "sa.house_bill" },
    { "code": "mawb_no",                 "label": "MAWB No.",                              "w": 4,  "multiline": false, "maxlen": 40,   "seed": "sa.master_bill" },
