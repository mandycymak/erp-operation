    { "code": "consignee",               "label": "Consignee's Name and Address",          "w": 6,  "multiline": true,  "maxlen": 600,  "seed": "erp:awbhead.cgne_name + cgne_add1..5 | sa.consignee_name" },
    { "code": "issuing_carrier_agent",   "label": "Issuing Carrier's Agent, Name and City","w": 6,  "multiline": true,  "maxlen": 300,  "seed": "erp:awbhead.agnt_name + agnt_add1..5" },
    { "code": "accounting_info",         "label": "Accounting Information",                "w": 6,  "multiline": true,  "maxlen": 300,  "seed": "" },
    { "code": "agent_iata_code",         "label": "Agent's IATA Code",                     "w": 3,  "multiline": false, "maxlen": 20,   "seed": "" },
    { "code": "agent_account_no",        "label": "Account No.",                           "w": 3,  "multiline": false, "maxlen": 20,   "seed": "" },
    { "code": "airport_departure",       "label": "Airport of Departure",                  "w": 6,  "multiline": false, "maxlen": 80,   "seed": "erp:awbhead.pol_name | sa.pol" },
    { "code": "routing",                 "label": "Routing (To / By First Carrier)",       "w": 6,  "multiline": false, "maxlen": 120,  "seed": "sa.route_summary" },
